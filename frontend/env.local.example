NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# Or: NEXT_PUBLIC_SUPABASE_PROJECT_ID=your_ref (URL becomes https://YOUR_PROJECT_REF.supabase.co)
# Use either legacy anon JWT or new publishable key from Project Settings → API:
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Google OAuth: Supabase Dashboard → Authentication → Sign In / Providers → Google (Client ID & secret).
# Authentication → URL Configuration → add Redirect URL:
#   http://localhost:3000/auth/callback
# (and your production URL + /auth/callback when you deploy)
